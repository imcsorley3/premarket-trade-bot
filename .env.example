# ── Groq (free at groq.com) ────────────────────────────────────────────────────
GROQ_API_KEY=gsk_YOUR_GROQ_KEY_HERE

# ── Alpaca Paper Trading (free at alpaca.markets) ──────────────────────────────
ALPACA_API_KEY=YOUR_ALPACA_KEY_ID
ALPACA_SECRET_KEY=YOUR_ALPACA_SECRET_KEY

# ── Discord Notifications ──────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_TOKEN

# ── Trade Settings (edit freely) ───────────────────────────────────────────────
TAKE_PROFIT_PCT=5.0   # sell when position is up this %
STOP_LOSS_PCT=2.0     # sell when position is down this %
TRADE_VALUE=25.0      # dollars invested per trade
POLL_INTERVAL=60      # seconds between feed polls
